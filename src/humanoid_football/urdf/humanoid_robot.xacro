<?xml version="1.0"?>

<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="humanoid_robot">

  <!-- ================================================= -->
  <!-- MATERIALS -->
  <!-- ================================================= -->

  <material name="blue">
    <color rgba="0 0 1 1"/>
  </material>

  <material name="red">
    <color rgba="1 0 0 1"/>
  </material>

  <material name="white">
    <color rgba="1 1 1 1"/>
  </material>

  <material name="black">
    <color rgba="0.1 0.1 0.1 1"/>
  </material>

  <!-- ================================================= -->
  <!-- BASE / TORSO -->
  <!-- ================================================= -->

  <link name="base_link">

    <visual>
      <origin xyz="0 0 0.15"/>

      <geometry>
        <box size="0.28 0.22 0.30"/>
      </geometry>

      <material name="${robot_color}"/>
    </visual>

    <collision>
      <origin xyz="0 0 0.15"/>

      <geometry>
        <box size="0.28 0.22 0.30"/>
      </geometry>
    </collision>

    <inertial>
      <!-- LOWER CENTER OF MASS -->
      <origin xyz="0 0 0.05"/>

      <mass value="5.0"/>

      <!-- Huge roll/pitch inertia (ixx, iyy) makes the body un-tippable:
           planar_move sets velocity directly, so this does NOT affect driving,
           but it makes contact impulses (robot-robot rams, ball hits) produce
           negligible tilt before the plugin zeroes roll/pitch each step. -->
      <inertia
        ixx="100.0"
        ixy="0.0"
        ixz="0.0"
        iyy="100.0"
        iyz="0.0"
        izz="0.15"/>
    </inertial>

  </link>

  <!-- ================================================= -->
  <!-- HEAD -->
  <!-- ================================================= -->

  <link name="head">

    <visual>
      <geometry>
        <sphere radius="0.12"/>
      </geometry>

      <material name="white"/>
    </visual>

    <collision>
      <geometry>
        <sphere radius="0.12"/>
      </geometry>
    </collision>

    <inertial>
      <!-- Light head keeps the center of mass low for stability -->
      <mass value="0.4"/>

      <inertia
        ixx="0.004"
        ixy="0"
        ixz="0"
        iyy="0.004"
        iyz="0"
        izz="0.004"/>
    </inertial>

  </link>

  <joint name="head_joint" type="fixed">
    <parent link="base_link"/>
    <child link="head"/>

    <origin xyz="0 0 0.42"/>
  </joint>

  <!-- ================================================= -->
  <!-- LEFT LEG -->
  <!-- ================================================= -->

  <link name="left_leg">

    <visual>
      <!-- IMPORTANT: NEGATIVE Z -->
      <origin xyz="0 0 -0.22"/>

      <geometry>
        <cylinder radius="0.07" length="0.45"/>
      </geometry>

      <material name="black"/>
    </visual>

    <collision>
      <origin xyz="0 0 -0.22"/>

      <geometry>
        <cylinder radius="0.07" length="0.45"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 -0.22"/>

      <mass value="3.0"/>

      <inertia
        ixx="0.05"
        ixy="0"
        ixz="0"
        iyy="0.05"
        iyz="0"
        izz="0.02"/>
    </inertial>

  </link>

  <joint name="left_leg_joint" type="fixed">
    <parent link="base_link"/>
    <child link="left_leg"/>

    <origin xyz="0 0.11 0"/>
  </joint>

  <!-- LEFT FOOT -->

  <link name="left_foot">

    <visual>
      <origin xyz="0.04 0 -0.03"/>

      <geometry>
        <!-- BIGGER FEET -->
        <box size="0.24 0.16 0.06"/>
      </geometry>

      <material name="blue"/>
    </visual>

    <collision>
      <origin xyz="0.04 0 -0.03"/>

      <geometry>
        <box size="0.24 0.16 0.06"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="3.0"/>

      <inertia
        ixx="0.02"
        ixy="0"
        ixz="0"
        iyy="0.02"
        iyz="0"
        izz="0.02"/>
    </inertial>

  </link>

  <joint name="left_foot_joint" type="fixed">
    <parent link="left_leg"/>
    <child link="left_foot"/>

    <origin xyz="0 0 -0.45"/>
  </joint>

  <!-- ================================================= -->
  <!-- RIGHT LEG -->
  <!-- ================================================= -->

  <link name="right_leg">

    <visual>
      <origin xyz="0 0 -0.22"/>

      <geometry>
        <cylinder radius="0.07" length="0.45"/>
      </geometry>

      <material name="black"/>
    </visual>

    <collision>
      <origin xyz="0 0 -0.22"/>

      <geometry>
        <cylinder radius="0.07" length="0.45"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 -0.22"/>

      <mass value="3.0"/>

      <inertia
        ixx="0.05"
        ixy="0"
        ixz="0"
        iyy="0.05"
        iyz="0"
        izz="0.02"/>
    </inertial>

  </link>

  <joint name="right_leg_joint" type="fixed">
    <parent link="base_link"/>
    <child link="right_leg"/>

    <origin xyz="0 -0.11 0"/>
  </joint>

  <!-- RIGHT FOOT -->

  <link name="right_foot">

    <visual>
      <origin xyz="0.04 0 -0.03"/>

      <geometry>
        <box size="0.24 0.16 0.06"/>
      </geometry>

      <material name="red"/>
    </visual>

    <collision>
      <origin xyz="0.04 0 -0.03"/>

      <geometry>
        <box size="0.24 0.16 0.06"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="3.0"/>

      <inertia
        ixx="0.02"
        ixy="0"
        ixz="0"
        iyy="0.02"
        iyz="0"
        izz="0.02"/>
    </inertial>

  </link>

  <joint name="right_foot_joint" type="fixed">
    <parent link="right_leg"/>
    <child link="right_foot"/>

    <origin xyz="0 0 -0.45"/>
  </joint>

  <!-- ================================================= -->
  <!-- FOOT FRICTION -->
  <!-- ================================================= -->

  <gazebo reference="left_foot">
    <mu1>0.1</mu1>
    <mu2>0.1</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
  </gazebo>

  <gazebo reference="right_foot">
    <mu1>0.1</mu1>
    <mu2>0.1</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
  </gazebo>

  <!-- ================================================= -->
  <!-- PLANAR MOVE -->
  <!-- ================================================= -->

  <gazebo>
    <plugin name="${robot_name}_planar_move"
            filename="libgazebo_ros_planar_move.so">

      <!-- Run every physics step (1 kHz). The plugin holds roll/pitch/z by
           zeroing them each update; at a low rate the body drifts between
           updates and topples, so this must match the physics rate. -->
      <update_rate>1000</update_rate>

      <command_topic>cmd_vel</command_topic>

      <odometry_topic>odom</odometry_topic>

      <odometry_frame>odom</odometry_frame>

      <robot_base_frame>base_link</robot_base_frame>

      <ros>
        <namespace>/${robot_name}</namespace>
      </ros>

    </plugin>
  </gazebo>

</robot>